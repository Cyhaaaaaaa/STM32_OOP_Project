        <!-- Devices Layer -->
        <mxCell id="layer-dev" value="Devices 设备层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="145" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="layer-dev-desc" value="device_*.c&#xa;抽象设备行为：LED亮灭、UART收发 —— 不涉及任何芯片寄存器" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=bottom;spacingBottom=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="145" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- Middlewares Layer -->
        <mxCell id="layer-mw" value="Middlewares 中间件层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="layer-mw-desc" value="环形缓冲区、协议解析等&#xa;可复用的通用软件组件，与硬件无关" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=bottom;spacingBottom=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- BSP Layer (highlighted - the focus) -->
        <mxCell id="layer-bsp" value="BSP 板级支持包 ⭐ 核心" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="layer-bsp-desc" value="bsp_*.c&#xa;唯一能用 #include &quot;stm32f10x.h&quot; 的地方！&#xa;把硬件操作封装成抽象函数" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=bottom;spacingBottom=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="500" height="80" as="geometry" />
        </mxCell>

        <!-- Driver Layer -->
        <mxCell id="layer-drv" value="Driver 驱动层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="layer-drv-desc" value="STM32 标准外设库 (Driver/FWLIB/) —— 芯片原厂提供" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=bottom;spacingBottom=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="500" height="60" as="geometry" />
        </mxCell>

