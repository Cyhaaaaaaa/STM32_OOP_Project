        <mxCell id="s3-step7" value="⑦ 使能 RXNE + NVIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="445" y="1310" width="185" height="60" as="geometry" />
