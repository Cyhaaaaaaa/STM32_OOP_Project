        <!-- Row 2: Steps 5-8 -->
        <mxCell id="s3-step5" value="⑤ 配置 USART 参数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
