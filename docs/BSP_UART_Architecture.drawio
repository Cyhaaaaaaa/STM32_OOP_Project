        <mxCell id="s3-edge7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s3-step7" target="s3-step8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Down arrow from step4 to step5 -->
        <mxCell id="s3-edge-down" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="s3-step4" target="s3-step5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="742" y="1280" />
              <mxPoint x="127" y="1280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Return annotation -->
        <mxCell id="s3-return" value="return obj; → 返回遥控器给上层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="1310" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s3-edge-ret" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s3-step8" target="s3-return">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Right: annotation -->
        <mxCell id="s3-note" value="💡 上层调用示例&#xa;&#xa;UART_Config_t cfg = {&#xa;  .uart = BSP_UART_1,&#xa;  .baudrate = 115200,&#xa;  .data_bits = BSP_UART_DATA_8,&#xa;  .stop_bits = BSP_UART_STOP_1,&#xa;  .parity = BSP_UART_PARITY_NONE&#xa;};&#xa;struct UART_Periph* u1 =&#xa;  UART_Periph_Create(&amp;cfg);&#xa;// u1 就是不透明指针遥控器！" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontFamily=Courier New;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1185" width="370" height="160" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- SECTION 4: Interrupt Data Flow                                    -->
        <!-- ================================================================== -->

        <mxCell id="s4-title" value="四、中断接收数据流（收到的字节怎么传到上层）" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="1400" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s4-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="20" y="1440" width="1620" height="260" as="geometry" />
        </mxCell>

        <!-- Flow boxes -->
        <mxCell id="irq-hw" value="🔌 硬件&#xa;UART收到&#xa;一个字节" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1510" width="130" height="80" as="geometry" />
        </mxCell>

        <mxCell id="irq-itc" value="📄 stm32f10x_it.c&#xa;USART1_IRQHandler()&#xa;↓调用&#xa;BSP_UART_GetInstance()&#xa;查索引簿拿遥控器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="1510" width="210" height="80" as="geometry" />
        </mxCell>

        <mxCell id="irq-bsp" value="📦 bsp_uart.c&#xa;BSP_UART_IRQHandler()&#xa;↓&#xa;检查 RXNE 标志&#xa;读 USART_ReceiveData()&#xa;拿到字节 byte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="1510" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="irq-cb" value="📞 回调触发&#xa;if (uart→rx_callback)&#xa;  uart→rx_callback(byte)&#xa;↓&#xa;调用上层注册的函数&#xa;把字节传出去" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="1510" width="210" height="80" as="geometry" />
        </mxCell>

        <mxCell id="irq-upper" value="📲 上层回调函数&#xa;（如 Middlewares&#xa; 环形缓冲区写入）&#xa;↓&#xa;收到字节，&#xa;存入缓冲区" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="1510" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Flow arrows -->
        <mxCell id="irq-edge1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="irq-hw" target="irq-itc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="irq-edge2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="irq-itc" target="irq-bsp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="irq-edge3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="irq-bsp" target="irq-cb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="irq-edge4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="irq-cb" target="irq-upper">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Bottom annotation: Register callback -->
        <mxCell id="irq-reg" value="注册回调的代码（在上层初始化时调用一次）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="240" y="1610" width="440" height="75" as="geometry" />
        </mxCell>
        <mxCell id="irq-reg-code" value="// 上层（如 Middlewares 环形缓冲区模块）&#xa;BSP_UART_RegisterRxCallback(u1, ringbuffer_write_byte);&#xa;                               // ↑ 遥控器    ↑ 收到字节时调这个函数" style="text;html=1;fontSize=10;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="240" y="1625" width="440" height="60" as="geometry" />
        </mxCell>

        <!-- Right: key insight -->
        <mxCell id="irq-insight" value="💡 关键理解" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="730" y="1610" width="650" height="75" as="geometry" />
        </mxCell>
        <mxCell id="irq-insight-text" value="• 中断函数名是芯片硬性规定（USART1_IRQHandler），所以不能放在 bsp_uart.c 里&#xa;• stm32f10x_it.c 只做转发：找实例 → 调 BSP_UART_IRQHandler，不包含任何业务逻辑&#xa;• 回调函数指针 = 控制反转：BSP 不知道数据要给谁，上层注册回调来告诉它" style="text;html=1;fontSize=10;fillColor=none;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="730" y="1625" width="650" height="60" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- SECTION 5: Key Knowledge Summary                                  -->
        <!-- ================================================================== -->

        <mxCell id="s5-title" value="五、核心设计模式总结" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="1720" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s5-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="20" y="1755" width="1620" height="210" as="geometry" />
        </mxCell>

        <!-- 6 knowledge cards -->
        <mxCell id="kp1" value="🔒 不透明指针模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="35" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp1-text" value=".h: struct X; (只有声明)&#xa;.c: struct X { ... }; (真正定义)&#xa;外部只能拿指针，通过函数操作&#xa;换芯片时上层代码一行不改" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="35" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="kp2" value="🌐 翻译层模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="300" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp2-text" value="通用枚举 → Translate() → 芯片寄存器&#xa;BSP_UART_1 → USART1 的基地址&#xa;只有 BSP 层知道 STM32 的细节&#xa;换芯片 = 只改 Translate() 的 switch" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="300" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="kp3" value="📞 回调注册模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="565" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp3-text" value="函数指针实现控制反转&#xa;BSP: &quot;我收到数据了，谁要？&quot;&#xa;上层: &quot;我来注册一个回调告诉你&quot;&#xa;收到字节 → rx_callback(byte)" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="565" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="kp4" value="📊 pool + instances 双数组" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="830" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp4-text" value="pool[3]: 仓库，按创建顺序存实体&#xa;instances[3]: 索引簿，按编号查指针&#xa;中断不能遍历 pool，必须 O(1) 查表&#xa;类比：仓库货架 vs 门口索引簿" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="830" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="kp5" value="🗂️ 静态内存池" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1095" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp5-text" value="static struct UART_Periph pool[3];&#xa;编译期确定大小，不用 malloc&#xa;嵌入式系统没有堆/不用堆都安全&#xa;固定上限 pool_idx >= 3 时拒绝" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="1095" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <mxCell id="kp6" value="⚡ 中断快速转发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1360" y="1770" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kp6-text" value="it.c: 只转发，不含业务逻辑&#xa;GetInstance() → O(1) 查索引&#xa;BSP_UART_IRQHandler() → 读寄存器&#xa;rx_callback() → 传递给上层" style="text;html=1;fontSize=9;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="1360" y="1787" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- Bottom overall summary line -->
        <mxCell id="summary" value="一句话总结：BSP 层用不透明指针隐藏芯片细节，用翻译函数转换通用枚举，用回调函数指针把数据传回上层。上层只和抽象概念打交道，换芯片时只改 BSP 层。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="1885" width="1350" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
