        <mxCell id="edge-m2b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="layer-mw" target="layer-bsp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-b2d" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="layer-bsp" target="layer-drv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Right side: Key Rule annotation -->
        <mxCell id="s1-rule" value="核心规则" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="350" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s1-rule-text" value="① 只有 BSP 层 .c 文件可以&#xa;   #include &quot;stm32f10x.h&quot;&#xa;&#xa;② 上层只调用 BSP 暴露的函数&#xa;   永远不直接操作寄存器&#xa;&#xa;③ 换芯片 = 只改 BSP 层" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="350" height="100" as="geometry" />
        </mxCell>

        <!-- Right side: Data flow explanation -->
        <mxCell id="s1-flow" value="调用链示例" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="200" width="540" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s1-flow-text" value="App 想发串口数据：&#xa;  app_xxx.c → device_uart.c → bsp_uart.c → STM32库&#xa;&#xa;App 想点亮 LED：&#xa;  app_xxx.c → device_led.c → bsp_gpio.c → STM32库" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="220" width="540" height="90" as="geometry" />
        </mxCell>

        <!-- stm32f10x_it.c special note -->
        <mxCell id="s1-it-note" value="⚠ stm32f10x_it.c（中断文件）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="325" width="540" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s1-it-text" value="特殊存在：中断函数名是芯片硬性规定的（USART1_IRQHandler）&#xa;但它只做转发 → BSP_UART_IRQHandler()，不包含业务逻辑" style="text;html=1;fontSize=11;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="540" height="55" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- SECTION 2a: bsp_uart.h — 对外暴露的纯净接口 (Left Column)          -->
        <!-- ================================================================== -->

        <mxCell id="s2-title" value="二、BSP UART 代码全景：.h 对外接口 vs .c 内部实现" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- bsp_uart.h container -->
        <mxCell id="s2h-container" value="bsp_uart.h — 对外暴露的纯净接口" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="530" width="800" height="580" as="geometry" />
        </mxCell>

        <!-- 1. Opaque Pointer -->
        <mxCell id="h-opaque" value="① 不透明指针声明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="40" width="350" height="75" as="geometry" />
        </mxCell>
        <mxCell id="h-opaque-code" value="struct UART_Periph;&#xa;// 只有声明，没有内容！外部只能拿指针" style="text;html=1;fontSize=11;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="55" width="350" height="60" as="geometry" />
        </mxCell>

        <!-- 2. Enums -->
        <mxCell id="h-enums" value="② 通用枚举（硬件无关词汇表）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="125" width="350" height="195" as="geometry" />
        </mxCell>
        <mxCell id="h-enums-list" value="BSP_UART_t:&#xa;  BSP_UART_1 / _2 / _3&#xa;&#xa;BSP_UART_DataBits_t:&#xa;  BSP_UART_DATA_8 / DATA_9&#xa;&#xa;BSP_UART_StopBits_t:&#xa;  STOP_1 / STOP_0_5 / STOP_2 / STOP_1_5&#xa;&#xa;BSP_UART_Parity_t:&#xa;  PARITY_NONE / ODD / EVEN" style="text;html=1;fontSize=10;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=8;spacingTop=20;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="140" width="350" height="180" as="geometry" />
        </mxCell>

        <!-- 3. Config Struct -->
        <mxCell id="h-config" value="③ 配置结构体（上层下达的「订单」）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="330" width="350" height="75" as="geometry" />
        </mxCell>
        <mxCell id="h-config-code" value="UART_Config_t { uart, baudrate,&#xa;  data_bits, stop_bits, parity }&#xa;// 完全不涉及 STM32 寄存器名！" style="text;html=1;fontSize=11;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="345" width="350" height="60" as="geometry" />
        </mxCell>

        <!-- 4. Callback Type -->
        <mxCell id="h-callback" value="④ 回调函数类型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="415" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="h-callback-code" value="typedef void (*BSP_UART_RxCallback_t)(uint8_t byte);" style="text;html=1;fontSize=10;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="430" width="350" height="40" as="geometry" />
        </mxCell>

        <!-- 5. Public APIs -->
        <mxCell id="h-apis" value="⑤ 公开 API 函数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="480" width="760" height="85" as="geometry" />
        </mxCell>
        <mxCell id="h-apis-list" value="// 构建与销毁&#xa;struct UART_Periph* UART_Periph_Create(UART_Config_t* cfg);  // 传入配置单，返回遥控器&#xa;// 中断服务&#xa;void BSP_UART_IRQHandler(struct UART_Periph* uart);            // 中断入口（由 it.c 调用）&#xa;struct UART_Periph* BSP_UART_GetInstance(BSP_UART_t uart);     // O(1) 查索引簿&#xa;void BSP_UART_RegisterRxCallback(struct UART_Periph*, cb);     // 注册接收回调&#xa;// 发送接口&#xa;void UART_SendByte / SendBytes / SendString(struct UART_Periph*, ...);" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=8;spacingTop=18;" vertex="1" parent="s2h-container">
          <mxGeometry x="20" y="495" width="760" height="70" as="geometry" />
        </mxCell>

        <!-- Right side annotation for opaque pointer -->
        <mxCell id="h-note-opaque" value="💡 不透明指针 = 密封遥控器&#xa;外面只能通过按钮（函数）操作&#xa;永远不知道里面是什么芯片" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="s2h-container">
          <mxGeometry x="400" y="40" width="240" height="75" as="geometry" />
        </mxCell>

        <!-- Right side annotation for enums -->
        <mxCell id="h-note-enum" value="💡 通用枚举 = 世界语&#xa;换芯片时只需修改 BSP 层的&#xa;翻译函数，上层代码不动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="s2h-container">
          <mxGeometry x="400" y="125" width="240" height="75" as="geometry" />
        </mxCell>

        <!-- Right side annotation for callback -->
        <mxCell id="h-note-cb" value="💡 函数指针 = 控制反转&#xa;BSP 不知道收到数据后要干嘛&#xa;上层注册回调来告诉它" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="s2h-container">
          <mxGeometry x="400" y="210" width="240" height="75" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- SECTION 2b: bsp_uart.c — 内部实现 (Right Column)                   -->
        <!-- ================================================================== -->

        <mxCell id="s2c-container" value="bsp_uart.c — #include &quot;stm32f10x.h&quot; 的内部实现" style="swimlane;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="530" width="800" height="580" as="geometry" />
        </mxCell>

        <!-- 1. Real struct -->
        <mxCell id="c-real" value="① 不透明指针的真正实体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="40" width="360" height="75" as="geometry" />
        </mxCell>
        <mxCell id="c-real-code" value="struct UART_Periph {&#xa;  USART_TypeDef*        usart;       // ← 真正的 STM32 寄存器地址！&#xa;  BSP_UART_RxCallback_t rx_callback; // ← 上层注册的回调函数指针&#xa;};" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="55" width="360" height="55" as="geometry" />
        </mxCell>

        <!-- 2. Pool -->
        <mxCell id="c-pool" value="② 静态内存池（仓库）— 不用 malloc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="140" width="360" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c-pool-code" value="static struct UART_Periph pool[3];&#xa;static uint8_t pool_idx = 0;&#xa;&#xa;// 仓库：按创建顺序存实体&#xa;// 先创建的串口 → pool[0]&#xa;// 后创建的串口 → pool[1]&#xa;// 不管你是 UART1 还是 UART3" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="152" width="360" height="125" as="geometry" />
        </mxCell>

        <!-- 3. Instances -->
        <mxCell id="c-instances" value="③ 索引簿 — 按串口编号 O(1) 查找" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="305" width="360" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c-instances-code" value="static struct UART_Periph* instances[3] = {0,0,0};&#xa;&#xa;// 索引簿：按串口编号存指针&#xa;// instances[BSP_UART_1] → UART1 的遥控器&#xa;// instances[BSP_UART_2] → UART2 的遥控器&#xa;// instances[BSP_UART_3] → UART3 的遥控器&#xa;// 中断来了直接 O(1) 查表，不用遍历！" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="317" width="360" height="125" as="geometry" />
        </mxCell>

        <!-- 4. TranslateResult -->
        <mxCell id="c-trans" value="④ 翻译草稿纸 UART_TranslateResult_t" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="470" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="c-trans-code" value="// 内部临时结构体，外面看不见&#xa;{ usart_base, tx_port, tx_pin, tx_gpio_rcc,&#xa;  rx_port, rx_pin, rx_gpio_rcc,&#xa;  usart_rcc, usart_on_apb1, irq_channel }&#xa;// 存翻译后的 STM32 寄存器参数" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="20" y="484" width="360" height="82" as="geometry" />
        </mxCell>

        <!-- Right side pool vs instances comparison -->
        <mxCell id="c-compare" value="pool vs instances 对比" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="40" width="370" height="240" as="geometry" />
        </mxCell>
        <mxCell id="c-compare-table" value="┌──────────┬──────────────┬──────────────────┐&#xa;│          │  pool[3]     │  instances[3]    │&#xa;├──────────┼──────────────┼──────────────────┤&#xa;│ 存的什么 │ 结构体实体   │ 指向实体的指针    │&#xa;│ 索引含义 │ 创建顺序     │ 串口编号          │&#xa;│ 谁在用   │ Create()分配  │ GetInstance()+中断 │&#xa;│ 查找速度 │ O(n) 需遍历  │ O(1) 直接取       │&#xa;│ 类比     │ 仓库的货架   │ 仓库门口的索引簿   │&#xa;└──────────┴──────────────┴──────────────────┘" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="52" width="370" height="225" as="geometry" />
        </mxCell>

        <!-- Right: 5. Internal funcs -->
        <mxCell id="c-funcs" value="⑤ 内部私有函数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="300" width="370" height="85" as="geometry" />
        </mxCell>
        <mxCell id="c-funcs-list" value="// static → 外部文件不可见！&#xa;static void BSP_UART_Translate(BSP_UART_t, UART_TranslateResult_t*);&#xa;  → 通用枚举 → STM32 寄存器参数&#xa;&#xa;static void BSP_UART_ConfigPin(GPIO_TypeDef*, uint16_t, GPIOMode_TypeDef, uint32_t);&#xa;  → 配置 TX/RX GPIO 引脚" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="314" width="370" height="70" as="geometry" />
        </mxCell>

        <!-- Right bottom: Translation example -->
        <mxCell id="c-trans-ex" value="翻译示例：BSP_UART_1 → STM32" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="410" width="370" height="155" as="geometry" />
        </mxCell>
        <mxCell id="c-trans-ex-text" value="输入（通用枚举）→  输出（STM32 方言）&#xa;──────────────────────────────────&#xa;BSP_UART_1  →  USART1 (0x40013800)&#xa;TX=PA9      →  GPIOA, GPIO_Pin_9&#xa;RX=PA10     →  GPIOA, GPIO_Pin_10&#xa;时钟        →  RCC_APB2Periph_USART1&#xa;中断号      →  USART1_IRQn (37)&#xa;&#xa;换芯片 = 只改这一段 switch-case！" style="text;html=1;fontSize=9;fontFamily=Courier New;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingTop=18;" vertex="1" parent="s2c-container">
          <mxGeometry x="410" y="422" width="370" height="140" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- SECTION 3: UART_Periph_Create 8-Step Flow                          -->
        <!-- ================================================================== -->

        <mxCell id="s3-title" value="三、UART_Periph_Create(cfg) — 8步构造流程" style="text;html=1;fontSize=18;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="1130" width="800" height="30" as="geometry" />
